# ============================================================================
# FIRESTORE (Firebase) — Database configuration
# ============================================================================
# The app now uses Firestore instead of SQLite/Prisma.
#
# To get these values:
# 1. Go to https://console.firebase.google.com/ and create a project.
# 2. Project Settings → Service Accounts → Generate new private key (JSON).
# 3. Copy the values from that JSON file into the env vars below.
#
#   FIREBASE_PROJECT_ID   →  "project_id" in the JSON
#   FIREBASE_CLIENT_EMAIL →  "client_email" in the JSON
#   FIREBASE_PRIVATE_KEY  →  "private_key" in the JSON (keep the quotes,
#                            it contains \n line breaks)
FIREBASE_PROJECT_ID=shadow-vault-47810
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@shadow-vault-47810.iam.gserviceaccount.com
